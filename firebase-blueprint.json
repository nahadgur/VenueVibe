{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "photoURL": { "type": "string", "description": "The user's profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Venue": {
      "title": "Venue",
      "description": "A venue listed for rent",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The name of the venue" },
        "description": { "type": "string", "description": "A detailed description of the venue" },
        "location": { "type": "string", "description": "The location/address of the venue" },
        "price": { "type": "number", "description": "The price per hour/day" },
        "capacity": { "type": "number", "description": "The maximum capacity of the venue" },
        "imageUrl": { "type": "string", "description": "The URL of the venue's main image" },
        "hostId": { "type": "string", "description": "The UID of the user who created the listing" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the venue was listed" }
      },
      "required": ["title", "location", "price", "capacity", "imageUrl", "hostId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles"
    },
    "/venues/{venueId}": {
      "schema": { "$ref": "#/entities/Venue" },
      "description": "Stores venue listings"
    }
  }
}
